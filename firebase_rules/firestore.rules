rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isTeacher() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /student_progress/{progressId} {
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isTeacher());
    }
  }
}
